<?xml version="1.0"?>
<ruleset name="EEDD Backend API">
    <description>Coding standard configuration for EEDD Backend API</description>

    <!-- Scan the app, config, routes, and database directories -->
    <file>app</file>
    <file>config</file>
    <file>routes</file>
    <file>database/factories</file>
    <file>database/seeders</file>

    <!-- Exclude directories -->
    <exclude-pattern>vendor</exclude-pattern>
    <exclude-pattern>storage</exclude-pattern>
    <exclude-pattern>bootstrap/cache</exclude-pattern>
    <exclude-pattern>node_modules</exclude-pattern>

    <!-- Use PSR-12 standard -->
    <rule ref="PSR12"/>

    <!-- Ligne max 120 caractères -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
        </properties>
    </rule>

    <!-- Show progress -->
    <arg value="p"/>
</ruleset>

